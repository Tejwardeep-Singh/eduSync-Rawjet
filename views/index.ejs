<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="apple-touch-icon" sizes="180x180" href="/images/ico/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/ico/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/ico/favicon-32x32.png">
    <link rel="manifest" href="/images/ico/site.webmanifest">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>EduSync | Smart School Management Platform</title>
</head>
<body>
<div id="main">
  
<nav>
    <div class="nav-left">

        <img src="/images/images/logo.png" alt="">

        <h2>EduSync</h2>

    </div>
    <div class="nav-right">
        <div class="desktop-links">

            <a href="/">Home</a>

            <a href="#features">Features</a>

            <a href="#portals">Portals</a>

            <a href="/images">Gallery</a>

            <div class="login-dropdown">

                <button>
                    Login
                    <i class="ri-arrow-down-s-line"></i>
                </button>

                <div class="dropdown-menu">

                    <a href="/studentlogin">
                        Student Login
                    </a>

                    <a href="/teacherlogin">
                        Teacher Login
                    </a>

                    <a href="/headlogin">
                        Admin Login
                    </a>

                </div>

            </div>

        </div>
        <div class="mobile-nav">

            <i class="ri-menu-line" id="menu-btn"></i>

            <div class="mobile-menu" id="mobile-menu">

                <a href="/">Home</a>

                <a href="#features">Features</a>

                <a href="#portals">Portals</a>

                <a href="/images">Gallery</a>

                <div class="mobile-login">

                    <h4>Login Portals</h4>

                    <a href="/studentlogin">
                        Student Login
                    </a>

                    <a href="/teacherlogin">
                        Teacher Login
                    </a>

                    <a href="/headlogin">
                        Admin Login
                    </a>

                </div>

            </div>

        </div>

    </div>

</nav>

  <section id="hero">
    <video autoplay muted loop playsinline>
      <source src="/videos/index_video.mp4" type="video/mp4">
    </video>
    <div class="overlay"></div>
    <div class="hero-content">
      <span>Modern Education Infrastructure</span>
      <h1>
        Synchronizing <br>
        Modern Education
      </h1>
      <p>
        EduSync is a modern institution management platform
        built to simplify administration, academics,
        attendance, examinations, and communication.
      </p>
      <div class="hero-buttons">
        <a href="/studentlogin" class="primary-btn">
          Student Portal
        </a>
        <a href="/teacherlogin" class="secondary-btn">
          Teacher Portal
        </a>
      </div>
    </div>
  </section>

  <section id="features">
    <div class="section-title">
      <span>FEATURES</span>
      <h2>Everything Your Institution Needs</h2>
    </div>
    <div class="feature-container">
      <div class="feature-card">
        <i class="ri-user-3-fill"></i>
        <h3>Student Management</h3>
        <p>
          Manage student records, attendance,
          performance, and academic workflows.
        </p>
      </div>
      <div class="feature-card">
        <i class="ri-book-open-fill"></i>
        <h3>Examination System</h3>
        <p>
          Conduct and manage examinations,
          marks, and academic reports efficiently.
        </p>
      </div>
      <div class="feature-card">
        <i class="ri-team-fill"></i>
        <h3>Teacher Dashboard</h3>
        <p>
          Empower faculty with streamlined
          academic and classroom tools.
        </p>
      </div>
      <div class="feature-card">
        <i class="ri-bar-chart-fill"></i>
        <h3>Analytics</h3>
        <p>
          Gain insights into academic performance
          and institutional growth.
        </p>
      </div>
    </div>
  </section>

  <section id="dashboard-preview">
    <div class="dashboard-left">
      <span>DASHBOARD</span>
      <h2>
        One Platform. <br>
        Complete Control.
      </h2>
      <p>
        EduSync provides centralized control for
        administrators, teachers, and students
        through a unified management system.
      </p>
    </div>
    <div class="dashboard-right">
      <img src="/images/images/dashboard.png" alt="Dashboard">
    </div>
  </section>

  <section id="portals">

    <div class="section-title">
      <span>ACCESS</span>
      <h2>Platform Portals</h2>
    </div>

    <div class="portal-container">

      <a href="/studentlogin" class="portal-card">

        <i class="ri-graduation-cap-fill"></i>

        <h3>Student Portal</h3>

        <p>
          Access attendance, marks,
          notices, and academic records.
        </p>

      </a>

      <a href="/teacherlogin" class="portal-card">

        <i class="ri-user-settings-fill"></i>

        <h3>Teacher Portal</h3>

        <p>
          Manage students, examinations,
          classes, and reports.
        </p>

      </a>

      <a href="/headlogin" class="portal-card">

        <i class="ri-admin-fill"></i>

        <h3>Administration</h3>

        <p>
          Full institutional management
          and system administration.
        </p>

      </a>

    </div>
  </section>

  <section id="stats">

    <div class="stat-box">
      <h2>5000+</h2>
      <p>Students Managed</p>
    </div>

    <div class="stat-box">
      <h2>200+</h2>
      <p>Teachers Connected</p>
    </div>

    <div class="stat-box">
      <h2>24/7</h2>
      <p>Platform Access</p>
    </div>

    <div class="stat-box">
      <h2>99%</h2>
      <p>System Reliability</p>
    </div>

  </section>

  <footer>

    <div class="footer-top">

      <div class="footer-brand">

        <h2>EduSync</h2>

        <p>
          A modern education management platform
          designed for institutions of the future.
        </p>

      </div>

      <div class="footer-links">

        <h3>Quick Links</h3>

        <a href="/">Home</a>
        <a href="#features">Features</a>
        <a href="#portals">Portals</a>

      </div>

      <div class="footer-links">

        <h3>Portals</h3>

        <a href="/studentlogin">Student</a>
        <a href="/teacherlogin">Teacher</a>
        <a href="/headlogin">Head</a>

      </div>

    </div>

    <div class="footer-bottom">

      <p>
        © 2026 EduSync. All Rights Reserved.
      </p>

    </div>

  </footer>
</div>

<script src="/javascripts/script.js"></script>

</body>
</html>
