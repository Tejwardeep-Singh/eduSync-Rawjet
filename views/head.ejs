</head>
<body>
    <main>
        <nav>
            <div class="nl">
                <img src="/images/images/LOGO.webp" alt="Logo here">
            </div>
            <div class="nr">
                <div class="nr-l">
                    <a href="/">Home</a>
                    <div id="login">
                        <a href="#" id="log_button">Login</a>
                        <div id="login_items">
                            <a href="/studentlogin">Student Login</a>
                            <a href="/teacherlogin">Teacher Login</a>
                            <a href="/headlogin">Head Login</a>
                        </div>
                    </div>
                    
                    <a href="/images">Images</a>
                </div>
                <div class="nr-r">
                    <i class="ri-menu-line"></i>
                </div>
            </div>
        </nav>  
        <div id="page1">
            <div id="pg1-container">
                <div id="panel">
                    <div class="panel_elem" id="hp1"><a href="/head">Personal Information</a></div>
                    <div class="panel_elem" id="hp2"><a href="#">Teacher Information</a></div>
                    <div class="panel_elem" id="hp3"><a href="#">Student Information</a></div>
                    <div class="panel_elem" id="hp3"><a href="#">Exams</a></div>
                    <div class="panel_elem" id="hp4"><a href="#">Leave Request</a></div>
                    <div class="panel_elem" id="hp5"><a href="#">Edit Details</a></div>
                    <div class="panel_elem" id="hp6"><a href="#">Change Password</a></div>
                </div>
                <div id="data">
                    <div class="part" id="personalInformation">
                        <h2>Personal Information</h2>
                        <div class="info">
                            <div class="infoElem" id="imageElem">
                                <div id="image">
                                    <% if (user && user.image) { %>
                                        <img src="/<%= user.image %>" alt="User Image" />
                                    <% } %>
                                </div>
                            </div>
                            <div class="infoElem">
                                <h2>Name:</h2>
                                <h3><%=user.name%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Father Name:</h2>
                                <h3><%=user.fatherName%>
                            </div>
                            <div class="infoElem">
                                <h2>Date Of Birth:</h2>
                                <h3><%=user.dob%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Date Of Joining:</h2>
                                <h3><%=user.dateOfJoining%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Mobile:</h2>
                                <h3><%=user.mobile%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Email:</h2>
                                <h3><%=user.email%></h2>
                            </div>
                        </div>
                    </div>
                    <div class="part" id="teacherInformation">
                        <div id="teacherPanel">
                            <h2 id="tp1">Search Teacher</h2>
                            <h2 id="tp2">Add Teacher</h2>
                        </div>
                        <div id="teacherBox">
                            <div id="teacherInfo" class="teacherInfo">
                                <div id="teacherInput">
                                    <form action="/headTeacher" method="get" enctype="multipart/form-data">
                                        <div id="label">
                                            <label for="id">ID: </label>
                                            <input type="number" id="id" name="id"required><br><br>     
                                        </div>
                                        <button type="submit">SHOW</button>
                                    </form>
                                </div>
                            </div>
                            <div id="teacherAdd" class="part" class="teacherInfo">
                                <h2>Add Or Update Teacher</h2>
                                <form action="/headTeacher" method="POST" enctype="multipart/form-data">
                                    <div id="label">
                                        <label for="id">Id: </label>
                                        <input type="number" id="login_id" name="login_id" value="<%= user1.login_id %>" required>
                                    </div>
                                    <div id="label">
                                        <label for="name">Name: </label>
                                        <input type="text" id="name" name="name" value="<%= user1.name %>" required><br><br>
                                    </div>
                                    <div id="label">
                                        <label for="fatherName">Father Name</label>
                                    <input type="text" id="fatherName" name="fatherName" value="<%= user1.fatherName %>" required><br><br>
                                    </div>
                                    <div id="label"> 
                                        <label for="dob">Date Of Birth: </label>
                                        <input type="date" id="dob" name="dob" value="<%= user1.dob %>" required><br><br></div>
                                    <div id="label">
                                        <label for="doj">date Of Joining: </label>
                                    <input type="date" id="dateOfJoining" name="dateOfJoining" value="<%= user1.dateOfJoining %>" required><br><br>
                                    </div>
                                    <div id="label">
                                        <label for="age">Age: </label>
                                    <input type="number" id="age" name="age" value="<%= user1.age %>" required><br><br>
                                    </div>
                                    <div id="label">
                                        <label for="mobile"> Mobile: </label>
                                    <input type="number" id="mobile" name="mobile" value="<%= user1.mobile%>" required><br><br>
                                    </div>
                                    <div id="label">
                                        <label for="email">Email: </label>
                                    <input type="email" id="email" name="email" value="<%= user1.email %>" required><br><br>
                                    </div>
                                    <div id="label">
                                        <label for="Photo">Photo: </label>
                                        <input type="file" name="image" accept="image/*" />
                                    </div>
                                    <button type="submit">Update</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="part" id="studentInformation"></div>
                    <div class="part" id="leaveRequest">
                        <div class="info" id="leaveInfoPanel">
                            <div class="infoElem"><h2>Id</h2></div>
                            <div class="infoElem"><h2>Name</h2></div>
                            <div class="infoElem"><h2>from Date</h2></div>
                            <div class="infoElem"><h2>Till Date</h2></div>
                            <div class="infoElem"><h2>Reason</h2></div>
                            <div class="infoElem"><h2>Approve</h2></div>
                        </div>      
                        <% leave.forEach(leaves=> { %>
                            <div class="info" id="leaveInfo">
                                <div class="infoElem"><%=leaves.id%></div>
                                <div class="infoElem"><%=leaves.name%></div>
                                <div class="infoElem"><%=leaves.from_date%></div>
                                <div class="infoElem"><%=leaves.to_date%></div>
                                <div class="infoElem"><%=leaves.reason%></div>
                                <div class="infoElem"><button>APPROVE</button></div>
                            </div>
                        <% }) %>
                    </div>
                    <div class="part" id="editDetails">
                        <h2>Edit Details</h2>
                        <form action="/head" method="POST" enctype="multipart/form-data">
                            <div id="label">
                                <label for="name">Name: </label>
                                <input type="text" id="name" name="name" value="<%= user.name %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="fatherName">Father Name</label>
                            <input type="text" id="fatherName" name="fatherName" value="<%= user.fatherName %>" required><br><br>
                            </div>
                            <div id="label"> 
                                <label for="dob">Date Of Birth: </label>
                                <input type="date" id="dob" name="dob" value="<%= user.dob %>" required><br><br></div>
                            <div id="label">
                                <label for="doj">date Of Joining: </label>
                            <input type="date" id="dateOfJoining" name="dateOfJoining" value="<%= user.dateOfJoining %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="age">Age: </label>
                            <input type="number" id="age" name="age" value="<%= user.age %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="mobile"> Mobile: </label>
                            <input type="number" id="mobile" name="mobile" value="<%= user.mobile%>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="email">Email: </label>
                            <input type="email" id="email" name="email" value="<%= user.email %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="Photo">Photo: </label>
                                <input type="file" name="image" accept="image/*" />
                            </div>
                            <button type="submit">Update</button>
                        </form>
                    </div>
                    <div class="part" id="changePassword"></div> 
                </div>
            </div>
        </div>
        <div id="footer">
            <div id="footer-container">
                <div class="fl">
                    <h2>CONTACT US</h2>
                    <div class="contact">
                        <h4>9780914581 (Head)</h4>
                        <h4>sandeepsinghsohian@gmail.com</h4>
                    </div>
                </div>
                <div class="fc">
                    <div class="quick-links">
                        <h2>Quick Links</h2>
                        <div class="contact">
                            <a href="/">Home</a>
                            <a href="/images">Images</a>
                            </div>
                    </div>
                </div>
                <div class="fr">
                    <h2>Location</h2>
                    <div class="contact">
                        <div id="map">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d548.6914284465247!2d74.90983231549603!3d31.690628893253695!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3919638655ecf77d%3A0x482bc38508456636!2sGovernment%20Elementary%20Smart%20School!5e1!3m2!1sen!2sin!4v1711472732719!5m2!1sen!2sin" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>
                </div>
            </div>  
        </div>
        <div id="horizontal-ruler"></div>
        <div id="copywright">
            <h3>@2024 Team Rawjet. All Rights Reserved.</h3>
        </div>
</main>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" integrity="sha512-7eHRwcbYkK4d9g/6tD/mhkf++eoTHwpNM9woBxtPUBWm67zeAfFC+HrdoE2GanKeocly/VxeLvIqwvCdk7qScg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" integrity="sha512-onMTRKJBKz8M1TnqqDuGBlowlH0ohFzMXYRNebz+yOcc5TQr/zAKsthzhuv0hiyUKEiQEQXEynnXCvNTOk50dg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    function loadTeacherDetails(teacherId) {
      fetch(`/head/teacher?id=${teacherId}`)
        .then(response => response.json())
        .then(data => {
          if (data.error) {
            alert(data.error);
          } else {
            // Populate form fields with data
            document.getElementById('name1').value = data.name || '';
            document.getElementById('fatherName1').value = data.fatherName || '';
            document.getElementById('dob1').value = data.dob ? data.dob.substring(0, 10) : '';
            document.getElementById('dateOfJoining1').value = data.dateOfJoining ? data.dateOfJoining.substring(0, 10) : '';
            document.getElementById('mobile1').value = data.mobile || '';
            document.getElementById('email1').value = data.email || '';
          }
        })
        .catch(err => {
          console.error('Error fetching teacher:', err);
          alert('Failed to load teacher details.');
        });
    }
  </script>
<script src="/javascripts/headScript.js"></script>
<script src="/javascripts/script.js"></script>
</body>
</html>