<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/ico/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/ico/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/ico/favicon-32x32.png">
    <link rel="manifest" href="/images/ico/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&family=Fjalla+One&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/student.css">
    <link rel="stylesheet" href="/stylesheets/head.css">
    <link rel="stylesheet" href="/stylesheets/teacher.css">
    <title>Student Panel | <%= user.name %></title>
</head>
<body>
    <main>
        <nav>
            <div class="nl">
                <img src="/images/images/LOGO.png" alt="">
            </div>
            <div class="nr">
                <div class="nr-l">
                    <a href="/">Home</a>
                    <a href="/student/logout">Logout</a>
                </div>
                <div class="nr-r">
                    <i class="ri-menu-line"></i>
                </div>
            </div>
        </nav>  
        <div id="page1">
            <div id="pg1-container">
                <div id="panel-container">
                    <div class="nr-r" id="panel-logo">
                        <i class="ri-menu-line"></i>
                    </div>
                    <div id="panel">
                        <div class="panel_elem" id="details"><a>Details</a></div>
                        <div class="panel_elem" id="datesheetPanel"><a>Datesheet</a></div>
                        <div class="panel_elem" id="leaveRequest"><a>leaveRequest</a></div>
                        <div class="panel_elem" id="report"><a>Reports</a></div>
                        <div class="panel_elem" id="editDetails"><a>Edit Details</a></div>
                        <div class="panel_elem" id="changePassword"><a>Change Password</a></div>
                    </div>
                </div>
                <div id="data">
                    <div class="part" id="personalInformation">
                        <!-- <h2>Personal Information</h2> -->
                        <div class="info">
                            <div class="infoElem" id="imageElem">
                                <div id="image">
                                    <% if (user && user.image) { %>
                                        <img src="<%= user.image %>" alt="User Image" />
                                    <% } %>
                                </div>
                            </div>
                            <div class="infoElem">
                                <h2>Name:</h2>
                                <h2><%=user.name%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Father Name:</h2>
                                <h3><%=user.fatherName%>
                            </div>
                            <div class="infoElem">
                                <h2>Mother Name:</h2>
                                <h3><%=user.motherName%>
                            </div>
                            <div class="infoElem">
                                <h2>City</h2>
                                <h3><%=user.city%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>State</h2>
                                <h3><%=user.state%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Date Of Birth:</h2>
                                <h2><%= new Date(user.dob).toLocaleDateString('en-GB', {
                                    day: '2-digit',
                                    month: 'long',
                                    year: 'numeric'
                                    }) %></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Age:</h2>
                                <h3><%=user.age%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Mobile:</h2>
                                <h3><%=user.mobile%></h2>
                            </div>
                            <div class="infoElem">
                                <h2>Email:</h2>
                                <h3><%=user.email%></h2>
                            </div>
                        </div>
                        <div class="stats">
                            <div class="stat-card">
                                <span>Class</span>
                                <h2><%= dashboard.classAssigned %></h2>
                            </div>

                            <div class="stat-card">
                                <span>Section</span>
                                <h2><%= dashboard.sectionAssigned %></h2>
                            </div>

                            <div class="stat-card">
                                <span>Subjects</span>
                                <h2><%= dashboard.totalSubjects %></h2>
                            </div>

                            <div class="stat-card">
                                <span>Leave Requests</span>
                                <h2><%= dashboard.totalLeaves %></h2>
                            </div>

                            <div class="stat-card">
                                <span>Approved Leaves</span>
                                <h2><%= dashboard.approvedLeaves %></h2>
                            </div>

                            <div class="stat-card">
                                <span>Pending Leaves</span>
                                <h2><%= dashboard.pendingLeaves %></h2>
                            </div>

                        </div>
                    </div>
                    <div class="part" id="marksBox">
                        <div id="viewMarks" class="marksElem">
                            <div id="viewMarksPanel">
                                <h2 id="vp1">Full Report</h2>
                                <h2 id="vp2">Particular Report</h2>
                            </div>
                            <div id="viewMarksBox" class="marksElem">
                                <div id="fullReport" class="marksElem report">
                                    <h2>Full Report</h2>
                                    <form action="/uploadMarks/student/fullReport" method="get" enctype="multipart/form-data">
                                        <input type="hidden" id="student_id" name="student_id" value="<%= user.id %>" required><br><br>
                                        <input type="hidden" id="nameValue" name="nameValue" value="<%= nameValue %>" required><br><br>
                                        <input type="hidden" id="sectionValue" name="sectionValue" value="<%= sectionValue %>" required><br><br>
                                        <button type="submit">SHOW</button>
                                    </form>
                                </div>
                                <div id="particularReport" class="marksElem report">
                                    <h2>Particular Report</h2>
                                    <form action="/uploadMarks/student/particularReport" method="get">
                                        <div id="label">
                                            <label for="exam_type">EXAM TYPE:</label>
                                            <select name="exam_type" id="exam_type">
                                                <option value="Final">Final</option>
                                                <option value="Half_Yearly">Half Yearly</option>
                                                <option value="Montly">Montly</option>
                                                <option value="Test">Test</option>
                                            </select>
                                        </div>
                                        <div id="label">
                                            <label for="date">Date:</label>
                                            <input type="date" name="date" id="date">
                                        </div>
                                        <input type="hidden" id="student_id" name="student_id" value="<%= user.id %>" required><br><br>
                                        <input type="hidden" id="nameValue" name="nameValue" value="<%= nameValue %>" required><br><br>
                                        <input type="hidden" id="sectionValue" name="sectionValue" value="<%= sectionValue %>" required><br><br>
                                        <button type="submit">Submit</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="part" id="changePasswordBox">
                        <h2>Change Password</h2>
                        <form action="/changePassword/student" method="POST">
                            <div id="label">
                                <label for="oldPassword">Old Password: </label>
                                <input type="password" id="oldPass" name="oldPass"  required><br><br>
                            </div>
                            <div id="label">
                                <label for="newPassword">New Password: </label>
                            <input type="password" id="newPass" name="newPass"  required><br><br>
                            </div>
                            <button type="submit">Update</button>
                        </form>
                    </div>
                    <div class="part" id="leaveRequestBox">
                        <div class="panel">
                            <h2 id="apply">Apply Leave</h2>
                            <h2 id="view">Leave Record</h2>
                        </div>
                        <div id="applyLeave" class="request">
                            <h2>Apply Leave</h2>
                            <form action="/leave/student" method="POST">
                                <div id="label">
                                    <label for="id">ID: </label>
                                    <input type="number" id="id" name="id" value="<%= apply.id %>" required><br><br>
                                </div>
                                <div id="label">
                                    <label for="name">Name:</label>
                                <input type="text" id="name" name="name" value="<%= apply.name %>" required><br><br>
                                </div>
                                <div id="label">
                                    <label for="kaksha">Class:</label>
                                <input type="number" id="kaksha" name="kaksha" value="<%= apply.kaksha %>" required><br><br>
                                </div>
                                <div id="label">
                                    <label for="section">Section:</label>
                                <input type="text" id="section" section="section" value="<%= apply.section %>" required><br><br>
                                </div>
                                <div id="label"> 
                                    <label for="from_date">From Date : </label>
                                    <input type="date" id="from_date" name="from_date" value="<%=apply.from_date %>" required><br><br></div>
                                <div id="label">
                                    <label for="to_late">Till Date :</label>
                                <input type="date" id="to_date" name="to_date" value="<%= apply.to_date %>" required><br><br>
                                </div>
                                <div id="label">
                                    <label for="reason">Reason: </label>
                                <input type="text" id="reason" name="reason" value="<%= apply.reason %>" required><br><br>
                                </div>
                                <button type="submit">Submit</button>
                            </form>
                        </div>
                        <div id="viewLeave" class="request">
                            <div class="table-wrapper">
                                <% if (studentLeaveDetails.length === 0) { %>

                                <div class="no-request">
                                    <h2>No Pending Leave Requests Yet</h2>
                                    <p>All leave requests have been processed.</p>
                                </div>

                            <% } else { %>
                                <table class="leave-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>From Date</th>
                                        <th>Till Date</th>
                                        <th>Reason</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% studentLeaveDetails.forEach(view => { %>
                                        <tr>
                                            <td><%= view.id %></td>
                                            <td><%= new Date(view.from_date).toLocaleDateString("en-IN") %></td>
                                            <td><%= new Date(view.to_date).toLocaleDateString("en-IN") %></td>
                                            <td><%= view.reason %></td>
                                            <td>
                                                <span class="status <%= view.status.toLowerCase() %>">
                                                    <%= view.status %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                            <% }%>
                            </div>
                        </div> 
                    </div>
                    <div class="part" id="editDetails">
                        <h2>Edit Details</h2>
                        <form action="/student/editDetails" method="POST" enctype="multipart/form-data">
                            <div id="label">
                                <label for="name">Name: </label>
                                <input type="text" id="name" name="name" value="<%= user.name %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="fatherName">Father Name:</label>
                            <input type="text" id="fatherName" name="fatherName" value="<%= user.fatherName %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="motherName">Mother  Name:</label>
                            <input type="text" id="motherName" name="motherName" value="<%= user.motherName %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="city">City:</label>
                            <input type="text" id="city" name="city" value="<%= user.city %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="state">State:</label>
                            <input type="text" id="state" name="state" value="<%= user.state %>" required><br><br>
                            </div>
                            <div id="label"> 
                                <label for="dob">Date Of Birth: </label>
                                <input type="date" id="dob" name="dob" value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>" required><br><br></div>
                            <div id="label">
                                <label for="age">Age: </label>
                            <input type="number" id="age" name="age" value="<%= user.age %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="mobile"> Mobile: </label>
                            <input type="number" id="mobile" name="mobile" value="<%= user.mobile%>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="email">Email: </label>
                            <input type="email" id="email" name="email" value="<%= user.email %>" required><br><br>
                            </div>
                            <div id="label">
                                <label for="Photo">Photo: </label>
                                <input type="file" name="image" accept="image/*" />
                            </div>
                            <button type="submit">SUBMIT</button>
                        </form>
                    </div>
                    <div class="part" id="datesheetBox">
                        <h2 style="text-align: center;">Datesheet</h2>
                        <div id="datesheetInput">
                            <form style="width:100%;" action="/datesheet/showStudent" method="get" enctype="multipart/form-data">
                                <input type="hidden" id="nameValue" name="nameValue" value="<%= nameValue %>" required><br><br>
                                <input type="hidden" id="sectionValue" name="sectionValue" value="<%= sectionValue %>" required><br><br>
                                <div id="label">
                                    <label for="examType">EXAM TYPE:</label>
                                    <select name="examType" id="examType">
                                        <option value="Final">Final</option>
                                        <option value="Half_Yearly">Half Yearly</option>
                                        <option value="Montly">Montly</option>
                                        <option value="Test">Test</option>
                                    </select>
                                </div>
                                <div id="label">
                                    <label for="month">month: </label>
                                    <input type="month" id="month" name="month" placeholder="yyyy-mm"required><br><br>     
                                </div>
                                <button type="submit">SHOW</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div id="footer">
            <div id="footer-container">
                <div class="fl">
                    <h2>CONTACT US</h2>
                    <div class="contact">
                        <h4>1234567895 (Head)</h4>
                        <h4>head@gmail.com</h4>
                    </div>
                </div>
                <div class="fc">
                    <div class="quick-links">
                        <h2>Quick Links</h2>
                        <div class="contact">
                            <a href="/">Home</a>
                            <a href="/images">Images</a>
                            </div>
                    </div>
                </div>
                <div class="fr">
                    <h2>Location</h2>
                    <div class="contact">
                        <div id="map">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d548.6914284465247!2d74.90983231549603!3d31.690628893253695!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3919638655ecf77d%3A0x482bc38508456636!2sGovernment%20Elementary%20Smart%20School!5e1!3m2!1sen!2sin!4v1711472732719!5m2!1sen!2sin" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>
                </div>
            </div>  
        </div>
        <div id="horizontal-ruler"></div>
        <div id="copywright">
            <h3>@2026 Team Rawjet. All Rights Reserved.</h3>
        </div>
</main>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" integrity="sha512-7eHRwcbYkK4d9g/6tD/mhkf++eoTHwpNM9woBxtPUBWm67zeAfFC+HrdoE2GanKeocly/VxeLvIqwvCdk7qScg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" integrity="sha512-onMTRKJBKz8M1TnqqDuGBlowlH0ohFzMXYRNebz+yOcc5TQr/zAKsthzhuv0hiyUKEiQEQXEynnXCvNTOk50dg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/javascripts/studentScript.js"></script>
<script src="/javascripts/script.js"></script>
</body>
</html>