            <span>GALLERY</span>

            <h2>
                Campus Moments
            </h2>

        </div>

        <div class="masonry-grid">

            <img src="/images/images/p1.jpg" alt="">

            <img src="/images/images/p2.jpg" alt="">

            <img src="/images/images/p3.jpg" alt="">

            <img src="/images/images/p4.jpg" alt="">

