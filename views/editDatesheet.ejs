    <title>EduSync | Edit Datesheets</title>
</head>
<body>
    <main>
        <nav>
            <div class="nl">
                <img src="/images/images/LOGO.png" alt="Logo here">
            </div>
            <div class="nr">
                <div class="nr-l">
                    <a href="/">Home</a>
                    <a href="/images">Images</a>
                </div>
                <div class="nr-r">
                    <i class="ri-menu-line"></i>
                </div>
            </div>
        </nav>  
        <div id="page1">
            <div id="pg1-container">

    <h1><%= datesheet.exam_type %> Examination</h1>

    <div class="details">

        <div class="detail-box">
            <h3>Class</h3>
            <p><%= datesheet.class %></p>
        </div>

        <div class="detail-box">
            <h3>Section</h3>
            <p><%= datesheet.section %></p>
        </div>

        <div class="detail-box">
            <h3>Total Subjects</h3>
            <p><%= datesheet.exams.length %></p>
        </div>

    </div>

    <div>

        <form
    action="/datesheet/update/<%= datesheet._id %>"
    method="POST"
    id="edit-datesheet-form">

    <input type="hidden" name="class" value="<%= datesheet.class %>">
    <input type="hidden" name="section" value="<%= datesheet.section %>">
    <input type="hidden" name="exam_type" value="<%= datesheet.exam_type %>">

    <div id="edit-table-wrapper">

        <table id="edit-datesheet-table">

            <thead>

                <tr>
                    <th>Subject</th>
                    <th>Date</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                </tr>

            </thead>

            <tbody>

            <% datesheet.exams.forEach(exam=>{ %>

                <tr>

                    <td>
                        <%= exam.subject %>

                        <input
                            type="hidden"
                            name="subject"
                            value="<%= exam.subject %>">
                    </td>

                    <td>
                        <input
                            type="date"
                            name="exam_date"
                            value="<%= exam.exam_date %>"
                            required>
                    </td>

                    <td>
                        <input
                            type="time"
                            name="start_time"
                            value="<%= exam.start_time %>"
                            required>
                    </td>

                    <td>
                        <input
                            type="time"
                            name="end_time"
                            value="<%= exam.end_time %>"
                            required>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

    <button class="primary-btn">
        Update Datesheet
    </button>

</form>

    </div>

</div>
